{
    "$schema": "http://json.schemastore.org/template",
    "author": "Cratis",
    "classifications": [
        "Web",
        "ASP.NET",
        "Cratis",
        "Arc",
        "Chronicle"
    ],
    "identity": "Cratis.Templates.Web",
    "name": "Cratis Web Application",
    "shortName": "cratis",
    "description": "A template for creating a Cratis web application",
    "tags": {
        "language": "C#",
        "type": "project"
    },
    "sourceName": "CratisApp",
    "preferNameDirectory": true,
    "primaryOutputs": [
        {
            "path": "CratisApp.csproj"
        }
    ],
    "symbols": {
        "Framework": {
            "type": "parameter",
            "datatype": "choice",
            "choices": [
                {
                "choice": "net8.0",
                "description": ".NET 8"
                },
                {
                "choice": "net9.0",
                "description": ".NET 9"
                },
                {
                "choice": "net10.0",
                "description": ".NET 10"
                }
            ],
            "defaultValue": "net10.0",
            "description": "Target framework",
            "prompt": "Select target framework",
            "replaces": "TARGET_FRAMEWORK"
        },
        "ProjectGuid": {
            "type": "generated",
            "generator": "guid",
            "replaces": "PROJECT_GUID"
        }
    },
    "sources": [
        {
            "exclude": [
                "**/.template.config/**"
            ]
        }
    ],
    "postActions": [
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Cratis NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Cratis NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Cratis",
                "projectFileExtensions": ".csproj"
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Cratis Arc MongoDB NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Cratis.Arc.MongoDB NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Cratis.Arc.MongoDB",
                "projectFileExtensions": ".csproj"
            },
            "continueOnError": true
        },
        {
            "description": "Restore NuGet packages required by this project.",
            "manualInstructions": [
                {
                    "text": "Run 'dotnet restore'"
                }
            ],
            "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
            "continueOnError": true
        },
        {
            "description": "Install all frontend dependencies with yarn.",
            "manualInstructions": [
                {
                    "text": "Run 'yarn install'"
                }
            ],
            "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
            "args": {
                "executable": "yarn",
                "args": "install"
            },
            "continueOnError": true
        },
        {
            "description": "Open README.md with getting started instructions.",
            "actionId": "84C0DA21-51C8-4541-9940-6CA19AF46622",
            "continueOnError": true,
            "manualInstructions": [
                {
                    "text": "Your project is ready! Next steps:\n  1. Start infrastructure:  docker-compose up -d\n  2. Run the application:   dotnet run\n  3. Frontend dev server:   yarn dev\n\nSee README.md for full details."
                }
            ],
            "args": {
                "files": "1"
            }
        }
    ]
}