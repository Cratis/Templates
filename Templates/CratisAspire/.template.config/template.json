        {
            "description": "Restore NuGet packages required by this project.",
            "manualInstructions": [
                {
                    "text": "Run 'dotnet restore'"
                }
            ],
            "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
            "continueOnError": true
        },
        {
            "description": "Show getting started instructions.",
            "actionId": "AC1156F7-BB77-4DB8-B28F-24EEBCCA1E5C",
            "continueOnError": true,
            "manualInstructions": [
                {
                    "text": "Your project is ready! Next steps (exact commands, with your project name, are in README.md):\n  1. Install frontend dependencies:  cd into the web app folder, then run 'yarn install'\n  2. Run the application:            'dotnet run' on the .Composition project\n  3. Frontend dev server:            run 'yarn dev' in the web app folder"
                }
            ],
            "args": {
                "files": "1"
            }
        }
    ]
}
