{
    "$schema": "http://json.schemastore.org/template",
    "author": "Cratis",
    "classifications": [
        "Web",
        "ASP.NET",
        "Cratis",
        "Arc",
        "Chronicle",
        "Aspire"
    ],
    "identity": "Cratis.Templates.Aspire",
    "name": "Cratis Aspire Application",
    "shortName": "cratis-aspire",
    "description": "A template for creating a Cratis web application with .NET Aspire orchestration",
    "tags": {
        "language": "C#",
        "type": "solution"
    },
    "sourceName": "CratisAspire",
    "preferNameDirectory": true,
    "primaryOutputs": [
        {
            "path": "CratisAspire.sln"
        }
    ],
    "symbols": {
        "Framework": {
            "type": "parameter",
            "datatype": "choice",
            "choices": [
                {
                    "choice": "net9.0",
                    "description": ".NET 9"
                },
                {
                    "choice": "net10.0",
                    "description": ".NET 10"
                }
            ],
            "defaultValue": "net10.0",
            "description": "Target framework",
            "prompt": "Select target framework",
            "replaces": "TARGET_FRAMEWORK"
        },
        "ProjectGuid": {
            "type": "generated",
            "generator": "guid",
            "replaces": "PROJECT_GUID"
        },
        "CompositionGuid": {
            "type": "generated",
            "generator": "guid",
            "replaces": "COMPOSITION_GUID"
        },
        "InfrastructureGuid": {
            "type": "generated",
            "generator": "guid",
            "replaces": "INFRASTRUCTURE_GUID"
        }
    },
    "sources": [
        {
            "exclude": [
                "**/.template.config/**"
            ]
        }
    ],
    "postActions": [
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Cratis NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Cratis NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Cratis",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire/CratisAspire.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Cratis.Arc.MongoDB NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Cratis.Arc.MongoDB NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Cratis.Arc.MongoDB",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire/CratisAspire.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Cratis.Chronicle.Aspire NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Cratis.Chronicle.Aspire NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Cratis.Chronicle.Aspire",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Composition/CratisAspire.Composition.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Microsoft.Extensions.Http.Resilience NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Microsoft.Extensions.Http.Resilience NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Microsoft.Extensions.Http.Resilience",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Infrastructure/CratisAspire.Infrastructure.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Microsoft.Extensions.ServiceDiscovery NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Microsoft.Extensions.ServiceDiscovery NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Microsoft.Extensions.ServiceDiscovery",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Infrastructure/CratisAspire.Infrastructure.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add OpenTelemetry.Exporter.OpenTelemetryProtocol NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the OpenTelemetry.Exporter.OpenTelemetryProtocol NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "OpenTelemetry.Exporter.OpenTelemetryProtocol",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Infrastructure/CratisAspire.Infrastructure.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add OpenTelemetry.Extensions.Hosting NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the OpenTelemetry.Extensions.Hosting NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "OpenTelemetry.Extensions.Hosting",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Infrastructure/CratisAspire.Infrastructure.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add OpenTelemetry.Instrumentation.AspNetCore NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the OpenTelemetry.Instrumentation.AspNetCore NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "OpenTelemetry.Instrumentation.AspNetCore",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Infrastructure/CratisAspire.Infrastructure.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add OpenTelemetry.Instrumentation.Http NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the OpenTelemetry.Instrumentation.Http NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "OpenTelemetry.Instrumentation.Http",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Infrastructure/CratisAspire.Infrastructure.csproj"]
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add OpenTelemetry.Instrumentation.Runtime NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the OpenTelemetry.Instrumentation.Runtime NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "OpenTelemetry.Instrumentation.Runtime",
                "projectFileExtensions": ".csproj",
                "targetFiles": ["CratisAspire.Infrastructure/CratisAspire.Infrastructure.csproj"]
            },
            "continueOnError": true
        },
        {
            "description": "Restore NuGet packages required by this project.",
            "manualInstructions": [
                {
                    "text": "Run 'dotnet restore'"
                }
            ],
            "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
            "continueOnError": true
        },
        {
            "description": "Install all frontend dependencies with yarn.",
            "manualInstructions": [
                {
                    "text": "Run 'yarn install' in the CratisAspire directory"
                }
            ],
            "actionId": "3A7C4B45-1F5D-4A30-959A-51B88E82B5D2",
            "args": {
                "executable": "yarn",
                "args": "install"
            },
            "continueOnError": true
        },
        {
            "description": "Open README.md with getting started instructions.",
            "actionId": "84C0DA21-51C8-4541-9940-6CA19AF46622",
            "continueOnError": true,
            "manualInstructions": [
                {
                    "text": "Your project is ready! Next steps:\n  1. Run the application:   dotnet run --project CratisAspire.Composition\n  2. Frontend dev server:   cd CratisAspire && yarn dev\n\nSee README.md for full details."
                }
            ],
            "args": {
                "files": "1"
            }
        }
    ]
}
