{
    "$schema": "http://json.schemastore.org/template",
    "author": "Cratis",
    "classifications": [
        "Web",
        "ASP.NET",
        "Cratis",
        "Arc",
        "Chronicle",
        "Aspire"
    ],
    "identity": "Cratis.Templates.Aspire",
    "name": "Cratis Aspire Application",
    "shortName": "cratis-aspire",
    "description": "A template for creating a Cratis web application with .NET Aspire orchestration",
    "tags": {
        "language": "C#",
        "type": "solution"
    },
    "sourceName": "CratisAspire",
    "preferNameDirectory": true,
    "primaryOutputs": [
        {
            "path": "CratisAspire.sln"
        }
    ],
    "symbols": {
        "Framework": {
            "type": "parameter",
            "datatype": "choice",
            "choices": [
                {
                    "choice": "net9.0",
                    "description": ".NET 9"
                },
                {
                    "choice": "net10.0",
                    "description": ".NET 10"
                }
            ],
            "defaultValue": "net10.0",
            "description": "Target framework",
            "prompt": "Select target framework",
            "replaces": "TARGET_FRAMEWORK"
        },
        "ProjectGuid": {
            "type": "generated",
            "generator": "guid",
            "replaces": "PROJECT_GUID"
        },
        "CompositionGuid": {
            "type": "generated",
            "generator": "guid",
            "replaces": "COMPOSITION_GUID"
        },
        "InfrastructureGuid": {
            "type": "generated",
            "generator": "guid",
            "replaces": "INFRASTRUCTURE_GUID"
        }
    },
    "sources": [
        {
            "exclude": [
                "**/.template.config/**"
            ]
        }
    ],
    "postActions": [
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Cratis NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Cratis NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Cratis",
                "projectFileExtensions": ".csproj",
                "targetFiles": "[\"**/CratisAspire.csproj\"]"
            },
            "continueOnError": true
        },
        {
            "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
            "description": "Add Cratis.Arc.MongoDB NuGet package.",
            "manualInstructions": [
                {
                    "text": "Add a reference to the Cratis.Arc.MongoDB NuGet package"
                }
            ],
            "args": {
                "referenceType": "package",
                "reference": "Cratis.Arc.MongoDB",
                "projectFileExtensions": ".csproj",
                "targetFiles": "[\"**/CratisAspire.csproj\"]"
            },
            "continueOnError": true
